# Secrets - never commit
.openrouter_key
*.key

# Client / SEE proprietary source - kept local, not distributed
*.ai
*Graphic_Dimensions*
# official SEE brand sources (presentation INDD/PDF, artwork-guidelines PDF, vector logo PDF):
# copyright-protected SEE property — the tools read them from here at runtime but they are
# never committed. The committed assets/see_logo.png is the only distributed brand asset.
assets/brand/
SE_Graphics_Production_Department_Roles.docx

# Redundant bundle (GitHub offers "Download ZIP") + runtime data
SEE_Wall_Template_Kit.zip
proof_log.xlsx

# Doc render-sources (the PDFs are the deliverables; HTML kept local for edits)
docs/*.html

# Scratch / generated at runtime
*_preflight.*
_intake_*.png
_intake_ai_dryrun.json
_proof_thumb*.png
_proof_mark*.png
# demo rehearsal outputs — hold renamed copies of client (Syntron) data that dodge *Graphic_Dimensions*
demo_scratch/
# tool outputs generated into the repo root at runtime (canonical copies live in examples/)
*_Spec_Packet.html
*_Spec_Packet.pdf
*_JOB_PROOF.html
*_JOB_PROOF.pdf
# intake outputs (client-derived; written to cwd when run live, e.g. during a demo)
booth_spec_*_DRAFT.json
*_intake_review.md
# a CONFIRMED booth file for a real job is client data — keep any at the repo root out
# (root-anchored so the tracked examples/ booth file is unaffected)
/booth_spec_*.json
# live-job working folders (client data: booth files, source decks, deliverables)
jobs/
# template preview written to cwd (can carry client data, e.g. a Syntron preview)
templates_preview.*
# job dashboard written to cwd (lists real jobs — can carry client data)
job_dashboard.*
# client design templates written to cwd (per-panel; can carry client data)
*_Client_Templates.html
*_Client_Templates.pdf
*_template.pdf

# OS / Python
.DS_Store
__pycache__/
*.pyc
.pytest_cache/
.venv*/
*.zip
# internal-only Claude context (client names, people, strategy) — the PUBLIC CLAUDE.md is committed
CLAUDE.local.md
# internal call-prep / strategy notes (client names + internal plans — never public)
Call_Prep_Notes.md
# leadership-share PDFs built from the public example (regenerate from the tools; keep out of the repo)
*_SAMPLE.pdf
SEE_Job_Dashboard*.pdf
SEE_Artwork_Check*.pdf
SEE_Client_Design_Templates*.pdf
